root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.toml]
indent_size = 4

[*.md]
# Markdown uses trailing spaces for hard line breaks.
trim_trailing_whitespace = false

[*.{ps1,psm1}]
indent_size = 4
end_of_line = crlf

[*.sh]
indent_size = 2
end_of_line = lf

[*.R]
indent_size = 2

[Makefile]
indent_style = tab
