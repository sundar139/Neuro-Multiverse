# Claude Code project memory
*.memory.md
.agent-memory/

# Environment and secrets
.env
.env.*
!.env.example

# Python environments and caches
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# Coverage and test artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/

# Tool caches
.cache/
.pre-commit-cache/

# R and renv
.Rhistory
.RData
.Rproj.user/
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/
renv/staging/

# IDE-local state that should not be shared
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.code-workspace

# Agent tool settings are per-user and machine-local.
# Ignored here rather than only in a global excludes file: a global excludes
# path configured on Windows is unresolvable to git running inside WSL2, so
# without this rule the file shows as untracked on the Linux side and a broad
# `git add` would stage it.
.claude/settings.local.json

# Research data — never versioned
data/raw/
data/derivatives/
data/interim/
data/features/
work/
scratch/
results/
artifacts/

# Filled preprocessing plans and completed QC checklists are external evidence:
# they carry an external data root, an opaque selection, and reviewer marks.
# Only the templates are versioned.
configs/preprocessing/*
!configs/preprocessing/*.template.yaml
!configs/preprocessing/*.template.md

# Neuroimaging working directories and container payloads
workdir/
fmriprep_work/
freesurfer/
containers/images/

# Imaging, array, and model-weight formats
*.nii
*.nii.gz
*.gii
*.mgz
*.mgh
*.trk
*.h5
*.hdf5
*.npy
*.npz
*.zarr/
*.pt
*.pth
*.ckpt
*.onnx
*.safetensors
*.joblib

# Dataset archives
*.tar
*.tar.gz
*.tgz
*.zip
*.7z

# Licensed material — never versioned
license.txt

# WSL and OS metadata
.DS_Store
Thumbs.db
desktop.ini
*.Identifier
